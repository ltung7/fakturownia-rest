{
    "name": "fakturownia-rest",
    "version": "0.1.0",
    "description": "Fully-typed Node.js wrapper for the Fakturownia REST API",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "prepare": "npm run build",
        "prepublishOnly": "npm run build",
        "xc": "npm run build && node sc/script.ts", 
        "sc": "node sc/script.ts" 
    },
    "keywords": [
        "fakturownia",
        "invoicing",
        "api",
        "typescript"
    ],
    "license": "MIT",
    "dependencies": {
        "axios": "^1.7.0"
    },
    "devDependencies": {
        "typescript": "^5.4.0",
        "@types/node": "^20.0.0"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}